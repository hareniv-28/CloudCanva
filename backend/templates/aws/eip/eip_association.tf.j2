resource "aws_eip_association" "{{id.replace('-','_')}}" {
  {% if refs is defined and refs.instance is defined %}
  instance_id   = aws_instance.{{refs.instance.replace('-','_')}}.id
  {% endif %}
  {% if refs is defined and refs.eip is defined %}
  allocation_id = aws_eip.{{refs.eip.replace('-','_')}}.id
  {% endif %}
}