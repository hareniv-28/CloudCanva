resource "aws_vpc_security_group_egress_rule" "{{ id.replace('-', '_') }}_egress_rule" {
  {% if refs is defined and refs.security_group is defined %}
  security_group_id = aws_security_group.{{ refs.security_group.replace('-', '_') }}.id
  {% endif %}
  ip_protocol       = "{{ protocol }}"
  from_port         = {{ from_port }}
  to_port           = {{ to_port }}
  {% if cidr_blocks is defined and cidr_blocks %}
  {% if cidr_blocks is string %}
  cidr_ipv4         = "{{ cidr_blocks }}"
  {% else %}
  cidr_ipv4         = "{{ cidr_blocks[0] }}"
  {% endif %}
  {% elif cidr_ipv4 is defined and cidr_ipv4 %}
  cidr_ipv4         = "{{ cidr_ipv4 }}"
  {% else %}
  cidr_ipv4         = "0.0.0.0/0"
  {% endif %}
  {% if ipv6_cidr_blocks is defined and ipv6_cidr_blocks %}
  cidr_ipv6         = "{{ ipv6_cidr_blocks[0] }}"
  {% endif %}
  
  description       = "{{ description|default('') }}"

  tags = {
    {% if tags is defined and tags %}
    {% for key, value in tags.items() %}
    {{ key }} = "{{ value }}"
    {% endfor %}
    {% endif %}
  }
}
