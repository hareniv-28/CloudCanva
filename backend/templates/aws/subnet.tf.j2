resource "aws_subnet" "{{ id.replace('-', '_') }}" {
  {% if refs is defined and refs.vpc is defined %}
  vpc_id            = aws_vpc.{{refs.vpc.replace('-','_')}}.id
  {% endif %}
  cidr_block        = "{{ cidr_block }}"
  availability_zone = "{{ availability_zone | default('eu-north-1a') }}"

  map_public_ip_on_launch = {{ map_public_ip_on_launch | default(false) | lower }}

  tags = {
    Name = "{{ name | default('') }}"
    {% if tags is defined and tags %}
    {% for key, value in tags.items() %}
    {{ key }} = "{{ value }}"
    {% endfor %}
    {% endif %}
  }

  lifecycle {
    create_before_destroy = true
  } 
}
